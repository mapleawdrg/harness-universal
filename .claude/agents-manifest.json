{
  "_comment": "SubagentStop output-guard가 읽는 에이전트→기대 산출물 매핑. 새 에이전트 추가 시 case 문 수정 대신 이 파일만 갱신.",
  "_handoff_convention": "{PHASE}는 호출 시 첫 줄 'Phase: P{N}' 로 주입. 파일명은 *-p{N}.md 패턴. PHASE-agnostic 에이전트는 phase_scoped=false.",
  "_field_semantics": {
    "expected_output": "subagent-output-guard.sh가 SubagentStop 시 .harness/{value} 존재 여부 검증.",
    "phase_scoped": "expected_output에 {PHASE} 토큰 포함 여부.",
    "role": "generator | evaluator | cross-cutting (문서화 메타 — hook 미사용).",
    "next / next_on_pass / next_on_needs_work / routes_to": "에이전트 체인 그래프 (문서화 메타 — hook 미사용. 본문은 각 에이전트 .md의 Loop Termination + 에스컬레이션 섹션에 박힘).",
    "escalate_after_n_failures": "문서화 메타 — hook 미사용. 실제 에스컬레이션 트리거는 dev.md Step 4a, qa.md Step 6a에 명시. (H2 후속 작업: hook이 이 필드를 읽어 자동 라우팅)"
  },

  "agents": {
    "product-designer": {
      "expected_output": "product-design-p{PHASE}.md",
      "phase_scoped": true,
      "next": "product-reviewer",
      "role": "generator"
    },
    "product-reviewer": {
      "expected_output": "product-review-p{PHASE}.md",
      "phase_scoped": true,
      "next_on_pass": "architect",
      "next_on_needs_work": "product-designer",
      "role": "evaluator"
    },
    "architect": {
      "expected_output": "architect-design-p{PHASE}.md",
      "phase_scoped": true,
      "next": "architect-reviewer",
      "role": "generator"
    },
    "architect-reviewer": {
      "expected_output": "architect-review-p{PHASE}.md",
      "phase_scoped": true,
      "next_on_pass": "planner",
      "next_on_needs_work": "architect",
      "role": "evaluator"
    },
    "planner": {
      "expected_output": "sprint-contract-p{PHASE}.md",
      "phase_scoped": true,
      "next": "plan-reviewer",
      "role": "generator"
    },
    "plan-reviewer": {
      "expected_output": "plan-review-p{PHASE}.md",
      "phase_scoped": true,
      "next_on_pass": "dev",
      "next_on_needs_work": "planner",
      "role": "evaluator"
    },
    "dev": {
      "expected_output": "dev-report-p{PHASE}.md",
      "phase_scoped": true,
      "next": "qa",
      "escalate_after_n_failures": "explain",
      "role": "generator"
    },
    "qa": {
      "expected_output": "qa-report-p{PHASE}.md",
      "phase_scoped": true,
      "next_on_pass": "(complete)",
      "next_on_needs_work": "dev",
      "role": "evaluator"
    },
    "explain": {
      "expected_output": "error-log.md",
      "phase_scoped": false,
      "role": "cross-cutting",
      "routes_to": ["dev", "planner", "architect"]
    }
  }
}
