{
  "$schema": "./harness.config.schema.json",
  "_comment": "하네스 범용 배포용 중앙 설정. 에이전트가 프로젝트 고유 값을 참조할 때 이 파일을 읽는다. 이 파일이 없으면 에이전트는 기본 동작(drift-check skip 등)으로 fallback.",

  "project_name": "Investment Coach",
  "actor_role": "Captain",

  "roadmap_doc": "docs/rebuild_plan_v2.md",
  "scenario_id_pattern": "S1-S17",

  "drift_check_docs": [
    "docs/rebuild_plan_v2.md",
    "docs/architecture.md",
    "docs/TRD.md",
    "docs/PRD.md",
    "docs/supabase_schema.md",
    "knowledge/KNOWLEDGE-SCHEMA.md",
    "app/agent/workers/*.md"
  ],

  "domain_vocab": {
    "data_sources": ["yfinance", "Finnhub", "FRED", "pykrx", "Seeking Alpha", "Mboum"],
    "accounts": ["ISA", "IRP"],
    "channels": ["Telegram"]
  },

  "test_commands": {
    "lint": "make lint",
    "test": "make test",
    "coverage": "make test-coverage",
    "ci": "make check"
  },

  "coverage_targets": {
    "overall": 70,
    "core_business_logic": 90,
    "utility": 70,
    "io_layer": 60
  },

  "loop_limits": {
    "architect_reviewer": 3,
    "plan_reviewer": 3,
    "dev_qa": 3,
    "product_reviewer": 3,
    "explain_max_turns": 5
  },

  "_notes": {
    "plan_reviewer_step_4_5": "drift_check_docs 리스트 중 존재하지 않는 파일은 soft-skip. HIGH→INFO 로 강등. 목록이 빈 배열이면 Step 4.5 전체 skip.",
    "scenario_id_pattern_optional": "roadmap 문서가 S-ID 체계를 쓰지 않는 프로젝트는 null로 설정 — qa/product-reviewer의 '시나리오 완결 체크'가 generic AC 체크로 대체됨"
  }
}
