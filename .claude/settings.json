{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/sandbox-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/post-change-tracker.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/session-summary.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/subagent-output-guard.sh\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash \".claude/hooks/wiki-ingest.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
